// X-Call customer portal schema
// Simple reseller portal: auth, KYC, packages, payment, selx provisioning

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum StoreRole {
  OWNER
  EMPLOYEE
}

enum StoreUserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum ServiceType {
  HUMAN
  AI
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROVISIONING
  ACTIVE
  PAYMENT_FAILED
  PROVISIONING_FAILED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

// Platform staff — separate from stores. Reviews KYC, manages packages/orders.
model Admin {
  id              String    @id @default(cuid())
  phone           String    @unique
  name            String?
  passwordHash    String?
  phoneVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// The reseller business account. Owns all business data (KYC, orders, subs, credentials).
model Store {
  id        String   @id @default(cuid())
  name      String? // business/legal name (set from KYC fullName)
  phone     String? // primary contact = owner's phone at signup (used for SELX provisioning)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        StoreUser[]
  kyc            KycSubmission?
  orders         Order[]
  subscriptions  Subscription[]
  selxCredential SelxCredential?
}

// A person who logs into a store: one OWNER + multiple EMPLOYEEs, each with their own login.
model StoreUser {
  id              String          @id @default(cuid())
  storeId         String
  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  phone           String          @unique
  name            String?
  passwordHash    String?
  role            StoreRole       @default(OWNER)
  status          StoreUserStatus @default(INVITED) // INVITED until password is set
  phoneVerifiedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([storeId])
  @@index([storeId, role])
}

model OtpChallenge {
  id          String    @id @default(cuid())
  phone       String
  codeHash    String
  purpose     String
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([phone, purpose])
}

model KycSubmission {
  id            String    @id @default(cuid())
  storeId       String    @unique
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fullName      String
  nidNumber     String
  frontFileKey  String
  backFileKey   String
  frontMimeType String
  backMimeType  String
  status        KycStatus @default(PENDING)
  rejectReason  String?   @db.Text
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([nidNumber])
}

model Package {
  id           String      @id @default(cuid())
  code         String      @unique
  name         String
  description  String?     @db.Text
  serviceType  ServiceType
  priceBdt     Int
  minutes      Int
  validityDays Int
  features     String      @default("") @db.VarChar(1000)
  isActive     Boolean     @default(true)
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orders Order[]
}

model Order {
  id             String      @id @default(cuid())
  storeId        String
  store          Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  packageId      String
  package        Package     @relation(fields: [packageId], references: [id])
  packageCode    String
  packageName    String
  serviceType    ServiceType
  priceBdt       Int
  minutes        Int
  validityDays   Int
  features       String      @db.VarChar(1000)
  status         OrderStatus @default(PENDING_PAYMENT)
  provisionError String?     @db.Text
  minutesCreditedAt DateTime? // set once the backend top-up succeeds; guards against double-crediting on retry
  paidAt         DateTime?
  activatedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  payment      Payment?
  subscription Subscription?

  @@index([storeId, status])
  @@index([status])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          String
  providerPaymentId String?
  amountBdt         Int
  status            PaymentStatus @default(PENDING)
  rawPayload        String?       @db.Text
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([providerPaymentId])
  @@index([status])
}

model Subscription {
  id           String             @id @default(cuid())
  storeId      String
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderId      String             @unique
  order        Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceType  ServiceType
  packageCode  String
  packageName  String
  minutesTotal Int
  status       SubscriptionStatus @default(ACTIVE)
  startsAt     DateTime           @default(now())
  expiresAt    DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([storeId, status])
  @@index([expiresAt, status])
}

model SelxCredential {
  id                   String   @id @default(cuid())
  storeId              String   @unique
  store                Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  selxUserId           Int
  selxUserSlug         String?
  bearerTokenEnc       String   @db.Text
  extension            String?
  extensionPasswordEnc String?  @db.Text
  webhookSecretEnc     String?  @db.Text
  phoneNumber          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorType  String? // "ADMIN" | "STORE_USER"
  action     String
  entityType String?
  entityId   String?
  meta       String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
