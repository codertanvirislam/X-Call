# App
DATABASE_URL="mysql://USER:PASSWORD@HOST:25060/DB_NAME?ssl-mode=REQUIRED"
APP_URL="http://localhost:3000"
SESSION_SECRET="change-me-to-a-long-random-string"
TOKEN_ENCRYPTION_KEY="change-me-32-chars-minimum!!!!!!"
NODE_ENV="development"

# First admin (seed)
ADMIN_PHONE="+8801XXXXXXXXX"
ADMIN_PASSWORD="change-me-admin-password"
ADMIN_NAME="Portal Admin"

# SMS / OTP
SMS_API_URL=""
SMS_API_KEY=""
SMS_SENDER_ID=""
# If true (or SMS_API_URL empty), OTP is logged to server console
SMS_DEV_MODE="true"
OTP_EXPIRY_MINUTES="5"

# S3 / Cloudflare R2 (KYC files)
S3_REGION="auto"
S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="pap"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL="https://pub-xxxx.r2.dev"

# Selx call-center backend (reseller partner)
SELX_BASE_URL="https://your-selx-domain"
SELX_PARTNER_API_KEY=""
SELX_PARTNER_WEBHOOK_SECRET=""
SELX_DEFAULT_BRIDGE_NUMBER=""

# Payment
# mock = dev checkout that completes via /api/payments/mock-complete
# webhook = external provider posts to /api/payments/webhook
PAYMENT_MODE="mock"
PAYMENT_WEBHOOK_SECRET="change-me-payment-webhook-secret"
